# Teleport stack environment template.
# Copy to .env and fill in values. Never commit the real .env (gitignored).
#
# The actual cluster_name / public_addrs / rp_id values are read from
# config/teleport.yaml — these env vars are kept here so the same values
# live in one file for ops convenience. Update both when changing them.
#
# Both required values are validated at compose start-up via `${VAR:?}` —
# leaving them blank fails loudly.

# Cluster name — lowercase, no spaces. Immutable after first boot.
TELEPORT_CLUSTER_NAME=

# Public DNS where the Teleport proxy is reachable. Must match the
# proxy_service.public_addrs and authentication.webauthn.rp_id values
# in config/teleport.yaml.
TELEPORT_PROXY_PUBLIC_ADDR=

# Optional: image version override.
# TELEPORT_VERSION=18.7.2

# Optional: published proxy port (only override if 443 is taken).
# TELEPORT_PROXY_PORT=443
