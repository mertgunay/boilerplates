# Teleport stack environment template.
# Copy to .env and edit. The actual cluster_name / public_addrs / rp_id
# values are read from config/teleport.yaml — these env vars are kept
# for ops convenience so the same values live in one file.

# Cluster name — lowercase, no spaces. Immutable after first boot.
TELEPORT_CLUSTER_NAME=my-cluster

# Public DNS where the Teleport proxy is reachable.
TELEPORT_PROXY_PUBLIC_ADDR=teleport.example.com

# Optional: image version override.
# TELEPORT_VERSION=18.7.2

# Optional: published proxy port (only override if 443 is taken).
# TELEPORT_PROXY_PORT=443
