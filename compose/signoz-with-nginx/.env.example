# SigNoz (with nginx reverse proxy) environment template.
# Copy to .env and fill in values. Never commit the real .env (gitignored).

# Required: JWT signing secret for SigNoz UI auth. Generate with:
#   openssl rand -hex 32
SIGNOZ_JWT_SECRET=

# Optional: image versions.
# SIGNOZ_VERSION=v0.120.0
# SIGNOZ_OTELCOL_VERSION=v0.144.3

# Optional: identify this collector in produced metrics. Defaults to "signoz".
# SIGNOZ_HOST_NAME=signoz

# Optional: published port overrides.
# NGINX_PORT=80
# OTLP_GRPC_PORT=4317
# OTLP_HTTP_PORT=4318
