# Grafana LGTM stack environment template.
# Copy to .env and fill in values. Never commit the real .env (gitignored).

# Required: Grafana admin user password.
GRAFANA_ADMIN_PASSWORD=

# Optional: admin username (default: admin).
# GRAFANA_ADMIN_USER=admin

# Optional: published port overrides.
# GRAFANA_PORT=3000
# TEMPO_OTLP_GRPC_PORT=4317
# TEMPO_OTLP_HTTP_PORT=4318
