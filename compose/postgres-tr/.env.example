# PostgreSQL credentials (tr_TR.UTF-8 variant)
# IMPORTANT: replace every value below before running this stack.
# Values are read by Docker secrets — never commit a file with real values.

POSTGRES_DB=changeme
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme

POSTGRES_PORT=5432

# Optional overrides
# COMPOSE_PROJECT_NAME=postgres-tr
# DOCKER_RESTART_POLICY=unless-stopped
