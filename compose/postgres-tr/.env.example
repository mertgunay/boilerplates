# PostgreSQL credentials (tr_TR.UTF-8 variant).
# Copy to .env and fill in values. Never commit the real .env (gitignored).
# Values are read by Docker secrets (see compose.yml) — never commit a real secret file.
#
# All three values are required. The official postgres image refuses to
# initialise an empty data directory without POSTGRES_PASSWORD set, so
# leaving these blank fails loudly on first boot.

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional: published port on the host. Change if 5432 conflicts.
# POSTGRES_PORT=5432

# Optional overrides.
# COMPOSE_PROJECT_NAME=postgres-tr
# DOCKER_RESTART_POLICY=unless-stopped
