# Selenium Grid environment template.
# Copy to .env and fill in values. Never commit the real .env (gitignored).

# Optional: published port and tuning overrides.
# HUB_PORT=4444
# SE_NODE_MAX_SESSIONS=8
# SE_SESSION_REQUEST_TIMEOUT=300

# Optional: required only if you uncomment the VNC block in compose.yml.
# SE_VNC_PASSWORD=
