# PostgreSQL credentials
# IMPORTANT: replace every value below before running this stack.
# Values are read by Docker secrets (see compose.yml) — never commit a real secret file.

POSTGRES_DB=changeme
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme

# Published port on the host. Change if 5432 conflicts.
POSTGRES_PORT=5432

# Optional: override the default project name.
# COMPOSE_PROJECT_NAME=postgres

# Optional: override container restart policy.
# DOCKER_RESTART_POLICY=unless-stopped
