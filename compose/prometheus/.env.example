# Prometheus stack environment template.
# Copy to .env and fill in values. Never commit the real .env (gitignored).

# Optional: published port overrides. Both are loopback-only by default.
# PROMETHEUS_PORT=9090
# CADVISOR_PORT=8080

# Optional: long-term remote write target. Uncomment the matching block in
# prometheus.yml to enable.
# REMOTE_WRITE_URL=https://prometheus-blocks-prod-us-central1.grafana.net/api/prom/push
# REMOTE_WRITE_USER=
# REMOTE_WRITE_PASSWORD=
