# Nginx Proxy Manager environment template.
# Copy to .env and fill in values. Never commit the real .env (gitignored).
#
# Two sets of variables that MUST match each other:
#   DB_MYSQL_USER     == MYSQL_USER
#   DB_MYSQL_PASSWORD == MYSQL_PASSWORD
#   DB_MYSQL_NAME     == MYSQL_DATABASE
# (NPM container reads DB_MYSQL_*, the MariaDB container creates its
# database / user from MYSQL_*.)

# --- NPM connection to the database ---
DB_MYSQL_USER=npm
DB_MYSQL_PASSWORD=changeme
DB_MYSQL_NAME=npm

# --- MariaDB initial setup ---
# Required: root password and the npm-user password (must match DB_MYSQL_PASSWORD above).
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=npm
MYSQL_USER=npm
MYSQL_PASSWORD=changeme

# --- File ownership inside the npm-data volume ---
# Default 0/0 means root. Set to your shell user's UID/GID (`id -u`, `id -g`)
# if you want to read the volume contents from the host without sudo.
# PUID=1000
# PGID=1000

# --- Optional: published port overrides ---
# NPM_HTTP_PORT=80
# NPM_HTTPS_PORT=443
# NPM_ADMIN_PORT=81
